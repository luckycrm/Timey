{
  "name": "timey",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"vite,api\" --prefix-colors \"cyan,magenta\" \"vite dev\" \"bun run server/index.ts\"",
    "dev:vite": "vite dev",
    "dev:api": "bun run --watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "PORT=4000 node .output/server/index.mjs",
    "spacetime:generate": "spacetime generate --lang typescript --out-dir src/module_bindings --module-path spacetimedb",
    "spacetime:publish": "spacetime publish --module-path spacetimedb --server maincloud"
  },
  "dependencies": {
    "@dytesdk/react-ui-kit": "^3.0.8",
    "@dytesdk/react-web-core": "^3.1.11",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-query-devtools": "^5.62.0",
    "@tanstack/react-router": "^1.162.0",
    "@tanstack/react-router-devtools": "^1.162.0",
    "@tanstack/react-router-ssr-query": "^1.162.0",
    "@tanstack/react-start": "^1.162.0",
    "oidc-client-ts": "^3.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-oidc-context": "^3.3.0",
    "sonner": "^2.0.7",
    "spacetimedb": "^2.0.2",
    "zeptomail": "^7.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "typescript": "^5.7.2",
    "vite": "^7.1.5",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
