{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    /* The following options are required by SpacetimeDB
     * and should not be modified
     */
    "target": "ESNext",
    "lib": [
      "ESNext",
      "dom"
    ],
    "module": "ESNext",
    "isolatedModules": true,
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "node_modules/spacetimedb/src/server/sys.d.ts"
  ],
  "exclude": []
}