# ── SpacetimeDB ──
SPACETIMEDB_DB_NAME=timeydb
SPACETIMEDB_HOST=https://maincloud.spacetimedb.com
# Server-side identity token for the Elysia backend (optional, auto-assigned on first connect)
SPACETIMEDB_SERVER_TOKEN=

# Vite (client-side)
VITE_SPACETIMEDB_DB_NAME=timeydb
VITE_SPACETIMEDB_HOST=https://maincloud.spacetimedb.com

# ── ZeptoMail ──
ZEPTOMAIL_TOKEN=your_zeptomail_token_here
ZEPTOMAIL_URL=https://api.zeptomail.com/v1.1/email
SENDER_EMAIL=noreply@timey.app

# ── Session ──
SESSION_SECRET=your_session_secret_here

# ── Dyte (Video Calls) ──
DYTE_ORG_ID=your_dyte_org_id
DYTE_API_KEY=your_dyte_api_key
DYTE_PRESET_NAME=group_call_host

# ── Server / CORS ──
# The origin that the browser sends requests from (must match frontend URL in production)
VITE_ORIGIN=http://localhost:5173
# Public URL of this app (used in invite links etc.)
APP_URL=http://localhost:5173
# API base URL — leave empty in dev (Vite proxy handles it). Set in production e.g. https://api.yourdomain.com
VITE_API_URL=
